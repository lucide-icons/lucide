<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet Package -->
    <PackageId>Lucide.Blazor</PackageId>
    <Version>0.1.0</Version>
    <Authors>lucide-contributors</Authors>
    <Description>Lucide icon Blazor components — use 1700+ beautiful icons as native Blazor components with full IntelliSense support.</Description>
    <PackageLicenseExpression>ISC</PackageLicenseExpression>
    <PackageProjectUrl>https://lucide.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lucide-icons/lucide</RepositoryUrl>
    <PackageTags>icons;svg;lucide;blazor;razor;components</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Lucide.Net\Lucide.Net.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
