<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <PackageId>Lucide.Net</PackageId>
    <Version>0.1.0</Version>
    <Authors>lucide-contributors</Authors>
    <Description>Lucide icon library for .NET - Beautiful and consistent icons</Description>
    <PackageLicenseExpression>ISC</PackageLicenseExpression>
    <PackageProjectUrl>https://lucide.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lucide-icons/lucide</RepositoryUrl>
    <PackageTags>icons;svg;lucide</PackageTags>
  </PropertyGroup>

</Project>
